# --- Groq (LLM for answer generation) ---
# TODO (YOU): Free key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- OpenAI key NOT needed anymore ---
# Embeddings now use @xenova/transformers (local, free, no API key)

# --- Qdrant Vector DB ---
# OPTION A — Local (run: docker run -p 6333:6333 qdrant/qdrant)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# OPTION B — Qdrant Cloud (recommended for deployment)
# Sign up free at https://cloud.qdrant.io, create a cluster, paste below:
QDRANT_URL=https://your-actual-cluster-url.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# --- Server ---
PORT=3000
